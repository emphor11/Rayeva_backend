generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                    String   @id @default(uuid())
  name                  String
  description           String
  primaryCategory       String?
  price                 Float    @default(0.0)
  subCategory           String?
  tags                  String[]
  sustainabilityFilters String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Proposal {
  id            String   @id @default(uuid())
  customerName  String?
  budgetLimit   Float
  estimatedCost Float
  productMix    Json
  costBreakdown Json
  impactSummary String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AIInteractionLog {
  id              String   @id @default(uuid())
  promptId        String   @default("unknown")
  promptVersion   String   @default("1.0.0")
  module          String?
  requestPayload  Json
  responsePayload Json
  status          String
  errorMessage    String?
  latencyMs       Int?
  timestamp       DateTime @default(now())
}
